# Editor
.vscode/

# Environment files (service-level .env only, not .env.* variants)
**/.env

# Images (local dev storage)
**/images/*

# Database files
**/*.db
**/*.sql

# Archives / backups
**/*.tar

# Python
.venv/
**/__pycache__/

# Directories excluded from repo
backups/
server-configs/
scripts/
dumps/
postmortem/
notes/

# Misc
**/*.jpeg
**/*.jpg
**/*.png
